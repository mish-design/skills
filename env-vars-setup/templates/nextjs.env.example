# ============================================
# ENVIRONMENT VARIABLES TEMPLATE - NEXT.JS
# ============================================
#
# INSTRUCTIONS FOR NEXT.JS:
# 1. Next.js automatically loads .env.local
# 2. Prefix with NEXT_PUBLIC_ to expose to browser
# 3. Variables without prefix are server-only
# 4. Copy: cp .env.example .env.local
# 5. NEVER commit .env.local to git!
#
# NEXT.JS SPECIFIC:
# - .env.local is automatically loaded
# - NEXT_PUBLIC_ variables are exposed to browser
# - Restart dev server after changing .env files
#

# ================ APPLICATION BASICS ================
NODE_ENV="development"
PORT="3000"
LOG_LEVEL="info"

# ================ DATABASE ================
# For API routes or server components
DATABASE_URL="postgresql://user:password@localhost:5432/dbname"

# ================ AUTHENTICATION (NEXTAUTH.JS) ================
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# OAuth providers for NextAuth.js
GOOGLE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"
GITHUB_CLIENT_ID="your-github-oauth-client-id"
GITHUB_CLIENT_SECRET="your-github-oauth-client-secret"

# ================ PUBLIC VARIABLES (EXPOSED TO BROWSER) ================
# WARNING: These values will be visible in browser!
# NEVER put secrets in NEXT_PUBLIC_ variables!

NEXT_PUBLIC_APP_NAME="My Next.js App"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="/api"
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID="UA-XXXXX-Y"

# Feature flags (client-side)
NEXT_PUBLIC_ENABLE_ANALYTICS="false"
NEXT_PUBLIC_ENABLE_DEBUG="true"
NEXT_PUBLIC_APP_VERSION="1.0.0"

# ================ SERVER-ONLY VARIABLES ================
# These are NOT exposed to browser (no NEXT_PUBLIC_ prefix)

# Stripe (server-side only)
STRIPE_SECRET_KEY="sk_test_51xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# Email services
SENDGRID_API_KEY="SG.xxx"

# AI/ML services (server-side)
OPENAI_API_KEY="sk-xxx"

# ================ DEPLOYMENT (VERCEL) ================
# Vercel automatically provides these
# VERCEL_URL="https://your-app.vercel.app"
# VERCEL_ENV="development"

# ================ CUSTOM VARIABLES ================
# API_BASE_URL="https://api.example.com"
# CUSTOM_FEATURE_FLAG="enabled"

# ============================================
# TROUBLESHOOTING:
# 1. "Variable not defined" → Restart dev server
# 2. Client can't see variable → Add NEXT_PUBLIC_ prefix
# 3. TypeScript errors → Check env.d.ts types
# ============================================