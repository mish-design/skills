# ============================================
# ENVIRONMENT VARIABLES TEMPLATE - NODE.JS BACKEND
# ============================================
#
# INSTRUCTIONS FOR NODE.JS:
# 1. Install dotenv: npm install dotenv
# 2. Load in entry point: require('dotenv').config()
# 3. Or use: import 'dotenv/config' (ESM)
# 4. Copy: cp .env.example .env.local
# 5. NEVER commit .env.local to git!
#
# NODE.JS SPECIFIC:
# - Requires dotenv package for loading
# - Load early in application entry point
# - All variables are server-side
#

# ================ APPLICATION BASICS ================
NODE_ENV="development"
PORT="3000"
LOG_LEVEL="info"
HOST="0.0.0.0"

# CORS configuration
CORS_ORIGIN="http://localhost:3000"
CORS_CREDENTIALS="true"

# ================ DATABASE ================
# PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/dbname"

# MongoDB
MONGODB_URI="mongodb://localhost:27017/mydb"

# Redis
REDIS_URL="redis://localhost:6379"

# Database pool settings
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_IDLE=30000

# ================ AUTHENTICATION & SECURITY ================
# JWT configuration
JWT_SECRET="generate-with-openssl-rand-base64-32"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="generate-another-secret-here"
JWT_REFRESH_EXPIRES_IN="30d"

# Password hashing
BCRYPT_SALT_ROUNDS=12

# Session configuration
SESSION_SECRET="session-secret-key"
SESSION_MAX_AGE=86400000  # 24 hours

# ================ API KEYS & EXTERNAL SERVICES ================
# Stripe
STRIPE_SECRET_KEY="sk_test_51xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"
STRIPE_PUBLISHABLE_KEY="pk_test_51xxx"

# Email services
SENDGRID_API_KEY="SG.xxx"
RESEND_API_KEY="re_xxx"
EMAIL_FROM="noreply@example.com"

# AI/ML services
OPENAI_API_KEY="sk-xxx"
ANTHROPIC_API_KEY="sk-ant-xxx"

# File storage
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_S3_BUCKET="your-bucket-name"
AWS_REGION="us-east-1"

# Monitoring & Logging
SENTRY_DSN="https://xxx@sentry.io/xxx"
DATADOG_API_KEY="xxx"
LOGTAIL_TOKEN="xxx"

# ================ RATE LIMITING & PERFORMANCE ================
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100
API_TIMEOUT_MS=30000

# ================ CACHE CONFIGURATION ================
CACHE_TTL=3600  # 1 hour in seconds
CACHE_ENABLED="true"

# ================ QUEUE & BACKGROUND JOBS ================
REDIS_QUEUE_HOST="localhost"
REDIS_QUEUE_PORT=6379
QUEUE_CONCURRENCY=5

# ================ CUSTOM APPLICATION VARIABLES ================
# API_BASE_URL="https://api.example.com"
# FEATURE_FLAG_ENABLED="true"
# MAX_FILE_SIZE="10485760"  # 10MB
# UPLOAD_DIR="./uploads"

# ================ DEPLOYMENT ================
# Docker
DOCKER_NETWORK="app-network"

# Kubernetes
K8S_NAMESPACE="default"
K8S_REPLICAS="2"

# ============================================
# LOADING INSTRUCTIONS:
# CommonJS: require('dotenv').config()
# ESM: import 'dotenv/config'
# TypeScript: import * as dotenv from 'dotenv'; dotenv.config()
# ============================================