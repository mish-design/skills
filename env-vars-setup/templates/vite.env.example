# ============================================
# ENVIRONMENT VARIABLES TEMPLATE - VITE (REACT/VUE/SVELTE)
# ============================================
#
# INSTRUCTIONS FOR VITE:
# 1. Prefix client variables with VITE_
# 2. Access via import.meta.env.VITE_*
# 3. Variables without VITE_ are server-only
# 4. Vite replaces variables at build time
# 5. Copy: cp .env.example .env.local
#
# VITE SPECIFIC:
# - Only VITE_ prefix works in browser
# - import.meta.env.VITE_VARIABLE_NAME
# - Build-time replacement (not runtime)
#

# ================ APPLICATION BASICS ================
NODE_ENV="development"
PORT="3000"
LOG_LEVEL="info"

# ================ DATABASE ================
# For backend/API (not exposed to browser)
DATABASE_URL="postgresql://user:password@localhost:5432/dbname"

# ================ PUBLIC VARIABLES (EXPOSED TO BROWSER) ================
# WARNING: These values will be visible in browser!
# MUST use VITE_ prefix for browser access

VITE_APP_NAME="My Vite App"
VITE_API_URL="http://localhost:3000/api"
VITE_SITE_URL="http://localhost:3000"
VITE_GOOGLE_ANALYTICS_ID="UA-XXXXX-Y"

# Feature flags (client-side)
VITE_ENABLE_ANALYTICS="false"
VITE_ENABLE_DEBUG="true"
VITE_APP_VERSION="1.0.0"

# Environment indicators
VITE_ENVIRONMENT="development"

# ================ SERVER-ONLY VARIABLES ================
# These are NOT exposed to browser (no VITE_ prefix)

# Authentication
JWT_SECRET="generate-with-openssl-rand-base64-32"

# Stripe (server-side only)
STRIPE_SECRET_KEY="sk_test_51xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# Email services
SENDGRID_API_KEY="SG.xxx"

# AI/ML services (server-side)
OPENAI_API_KEY="sk-xxx"

# OAuth providers
GOOGLE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"

# ================ BUILD CONFIGURATION ================
# Vite-specific build options
VITE_BUILD_SOURCEMAP="true"
VITE_BUILD_MINIFY="true"
VITE_BUILD_TARGET="esnext"

# ================ CUSTOM VARIABLES ================
# API_BASE_URL="https://api.example.com"
# CUSTOM_FEATURE_FLAG="enabled"

# ============================================
# TROUBLESHOOTING:
# 1. "import.meta.env is undefined" → Use VITE_ prefix
# 2. Variable not updating → Restart dev server
# 3. Build errors → Check variable names
# ============================================